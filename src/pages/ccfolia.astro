---
// ココフォリア部屋管理ページ
import { getEntry } from 'astro:content';

const roomEntry = await getEntry('rooms', 'rooms');
const rooms = roomEntry?.data?.rooms || [];
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ココフォリア部屋管理</title>
    <style>
        body {
            font-family: 'Kosugi Maru', sans-serif;
            background: #121214;
            color: #e1e1e6;
            margin: 0;
            padding: 40px 20px;
        }

        .wrapper {
            max-width: 900px;
            margin: 0 auto;
        }

        /* ポータルに戻るボタン */
        .back-to-portal {
            display: inline-block;
            border: 1px solid #e5e5ea;
            background: #ffffff;
            color: #1c1c1e;
            padding: 8px 16px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.85rem;
            margin-bottom: 20px;
            transition: background 0.2s, border-color 0.2s, transform 0.2s;
        }

        .back-to-portal:hover {
            border-color: #ff4a5a;
            background: #fafdff;
            transform: translateY(-1px);
        }

        header {
            margin-bottom: 40px;
            border-bottom: 1px solid #29292e;
            padding-bottom: 20px;
        }

        h1 {
            margin: 0 0 10px 0;
            font-size: 2rem;
            letter-spacing: 0.05em;
        }

        /* 部屋リスト */
        .room-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 20px;
        }

        .room-card {
            background: #ffffff;
            color: #1c1c1e;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #e5e5ea;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 120px;
            position: relative;
        }

        .room-info h3 {
            margin: 0 0 8px 0;
            font-size: 1.15rem;
            font-weight: bold;
        }

        .room-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
        }

        .room-link {
            display: inline-block;
            background: #1c1c1e;
            color: #ffffff;
            padding: 6px 14px;
            border-radius: 6px;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: bold;
            transition: background 0.2s;
            width: 100%;
            text-align: center;
        }

        .room-link:hover {
            background: #48484a;
        }
    </style>
</head>
<body>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Kosugi+Maru&display=swap" rel="stylesheet">
    <div class="wrapper">
        <a href={import.meta.env.BASE_URL} class="back-to-portal">← ポータルに戻る</a>

        <header>
            <h1>ココフォリア部屋管理</h1>
            <p style="color: #8d8d99; margin: 0;">セッション部屋のリンク一覧です</p>
        </header>

        <h2>部屋一覧</h2>
        <main class="room-grid">
            {rooms.length === 0 ? (
                <p style="color: #8d8d99; grid-column: 1/-1; text-align: center;">
                    登録されている部屋がありません。
                </p>
            ) : (
                rooms.map((room: any) => (
                    <div class="room-card">
                        <div class="room-info">
                            <h3>🎲 {room.name}</h3>
                        </div>
                        <div class="room-actions">
                            <a href={room.url} target="_blank" class="room-link">部屋に入る ↗</a>
                        </div>
                    </div>
                ))
            )}
        </main>
    </div>
</body>
</html>