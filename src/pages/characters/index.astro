---
import { getCollection } from 'astro:content';

// 1. 全てのキャラクター（Markdown）のデータを取得する
const allCharacters = await getCollection('characters');

// 各キャラのJSON本文をパースして、チャパレやいあきゃらのデータを裏でくっつけておく処理
const charactersWithData = allCharacters.map((entry: any) => {
  let ccfoliaData = null;
  try {
    ccfoliaData = JSON.parse(entry.body.trim());
  } catch (e) {
    console.error(`${entry.id} のJSONパースに失敗しました:`, e);
  }
  
  return {
    id: entry.id,
    frontmatter: entry.data,
    ccfolia: ccfoliaData?.data
  };
});
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Kosugi+Maru&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>探索者保管庫 - Character List</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            background: #121214;
            color: #e1e1e6;
            margin: 0;
            padding: 40px 20px;
            font-family: 'Kosugi Maru', sans-serif;
        }

        .wrapper {
            max-width: 1100px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 40px;
            border-bottom: 1px solid #29292e;
            padding-bottom: 20px;
        }

        h1 {
            margin: 0 0 10px 0;
            font-size: 2rem;
            letter-spacing: 0.05em;
        }

        .subtitle {
            color: #8d8d99;
            margin: 0;
            font-size: 0.9rem;
        }

        /* ポータルに戻るボタンのスタイル */
        .back-to-portal {
            display: inline-block;
            border: 1px solid #e5e5ea;
            background: #ffffff;
            color: #1c1c1e;
            padding: 8px 16px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.85rem;
            margin-bottom: 20px;
            transition: background 0.2s, border-color 0.2s, transform 0.2s;
        }

        .back-to-portal:hover {
            border-color: #ff4a5a;
            background: #fafdff;
            transform: translateY(-1px);
        }

        /* キャラクターカードを並べるグリッド */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
        }

        /* 個々のキャラクターカード */
        .card {
            background: #ffffff; /* ★背景を「白」に固定 */
            border-radius: 12px;
            overflow: hidden;
            text-decoration: none;
            color: #1c1c1e; /* ★文字色を白背景で見やすい濃いグレーに固定 */
            display: flex;
            flex-direction: column;
            border: 1px solid #e5e5ea;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            position: relative;
        }

        /* ホバーした時のアニメーション */
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 24px var(--card-accent-shadow, rgba(0, 0, 0, 0.5));
            border-color: var(--card-accent, #ff4a5a);
        }

        /* 立ち絵枠 */
        .card-img-wrapper {
            width: 100%;
            height: 240px;
            background: #121214;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid #29292e;
            position: relative;
        }

        .card-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: top center;
            transition: transform 0.3s ease;
        }

        .card:hover .card-img {
            transform: scale(1.05);
        }

        /* 立ち絵がないときのダミー枠 */
        .no-image {
            color: #494950;
            font-size: 0.9rem;
        }

        /* キャラクター基本情報 */
        .card-body {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            flex-grow: 1;
        }

        .card-title {
            margin: 0;
            font-size: 1.25rem;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        /* システム名のタグ */
        .system-tag {
            font-size: 0.75rem;
            background: var(--card-accent, #ff4a5a);
            color: #fff;
            padding: 3px 8px;
            border-radius: 4px;
            font-weight: normal;
        }

        .profession {
            font-size: 0.85rem;
            color: #545456; /* 白背景用の濃いグレー */
            margin: 0;
        }

        /* 簡易ステータスバー */
        .card-status {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            margin-top: auto;
            border-top: 1px solid #e5e5ea;
            padding-top: 12px;
        }

        .status-item {
            text-align: center;
        }

        .status-label {
            font-size: 0.7rem;
            color: #8e8e93; /* 白背景用の薄めグレー */
            display: block;
            margin-bottom: 2px;
        }

        .status-val {
            font-size: 0.9rem;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <a href="/" class="back-to-portal">← ポータルに戻る</a>

        <header>
            <h1>探索者保管庫</h1>
            <p class="subtitle">TRPG Characters Portfolio</p>
        </header>

        <main class="grid">
            {charactersWithData.map((chara: any) => {
                const cardAccent = chara.frontmatter.subColor || "#ff4a5a";
                const cardAccentShadow = `${cardAccent}20`; 

                return (
                    <a href={`/characters/${chara.id}`} class="card" style={`--card-accent: ${cardAccent}; --card-accent-shadow: ${cardAccentShadow};`}>
                        <div class="card-img-wrapper">
                            {chara.ccfolia?.iconUrl ? (
                                <img src={chara.ccfolia.iconUrl} alt={chara.frontmatter.name} class="card-img" />
                            ) : (
                                <div class="no-image">No Image</div>
                            )}
                        </div>

                        <div class="card-body">
                            <h2 class="card-title">
                                {chara.frontmatter.name}
                                <span class="system-tag">{chara.frontmatter.system}</span>
                            </h2>
                            <p class="profession">{chara.frontmatter.profession}</p>

                            <div class="card-status">
                                {chara.ccfolia?.status?.slice(0, 3).map((st: any) => (
                                    <div class="status-item">
                                        <span class="status-label">{st.label}</span>
                                        <span class="status-val">{st.value}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </a>
                );
            })}
        </main>
    </div>
</body>
</html>